{
    "__inputs": [
        {
            "name": "DS_PROMETHEUS",
            "label": "Prometheus",
            "description": "",
            "type": "datasource",
            "pluginId": "prometheus",
            "pluginName": "Prometheus"
        }
    ],
    "__requires": [
        {
            "type": "grafana",
            "id": "grafana",
            "name": "Grafana",
            "version": "10.0.0"
        },
        {
            "type": "datasource",
            "id": "prometheus",
            "name": "Prometheus",
            "version": "1.0.0"
        }
    ],
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "id": 1,
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
            "type": "stat",
            "title": "Active Agents",
            "datasource": "${DS_PROMETHEUS}",
            "targets": [
                {
                    "expr": "sum(up{job='agents'})"
                }
            ],
            "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
        },
        {
            "id": 2,
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
            "type": "alertlist",
            "title": "Active Alerts",
            "options": {
                "showInstance": true,
                "sortOrder": "Importance"
            }
        },
        {
            "id": 3,
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
            "type": "timeseries",
            "title": "Decisions Made (per minute)",
            "datasource": "${DS_PROMETHEUS}",
            "targets": [
                {
                    "expr": "rate(agent_manager_decisions_made_total[1m])"
                }
            ]
        },
        {
            "id": 4,
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
            "type": "timeseries",
            "title": "P95 Task Prioritization Duration",
            "datasource": "${DS_PROMETHEUS}",
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(agent_manager_task_prioritization_duration_seconds_bucket[5m])) by (le))"
                }
            ],
            "unit": "s"
        }
    ],
    "schemaVersion": 37,
    "style": "dark",
    "tags": [],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "",
    "title": "Advanced Agent Monitoring",
    "uid": "advanced-agent-monitoring",
    "version": 2
}
