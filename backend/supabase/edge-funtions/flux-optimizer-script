// backend/supabase/edge-funtions/flux-optimizer-script/index.ts
import { createClient, SupabaseClient } from 'https://esm.sh/@supabase/supabase-js@2';

// CORS Headers
const allowedOrigins = [
  'https://fluxrevenue.com.br',
  'https://app.fluxrevenue.com.br',
];

function getCorsHeaders(requestHeaders: Headers) {
  const requestOrigin = requestHeaders.get('origin') || "";
  const effectiveOrigin = allowedOrigins.includes(requestOrigin) ? 
    requestOrigin : 
    (requestOrigin.startsWith('http://localhost:') ? requestOrigin : allowedOrigins[0]);

  return {
    'Access-Control-Allow-Origin': effectiveOrigin,
    'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type, x-optimization-token',
    'Access-Control-Allow-Methods': 'GET, OPTIONS',
    'Access-Control-Max-Age': '86400',
  };
}

async function getActiveOptimizations(siteId: string, supabase: SupabaseClient) {
  try {
    console.log(`flux-optimizer-script: Fetching active configurations for site: ${siteId}`);
    const { data: configs, error } = await supabase
      .from('optimizer_configs')
      .select('config_name, config')
      .eq('site_id', siteId)
      .eq('is_active', true);
      
    if (error) {
      console.error(`flux-optimizer-script: Database error fetching optimizer_configs for site ${siteId}:`, error);
      throw error;
    }
    console.log(`flux-optimizer-script: Found ${configs?.length || 0} active configurations for site ${siteId}.`);
    return configs || [];
  } catch (error) {
    console.error(`flux-optimizer-script: Error in getActiveOptimizations for site ${siteId}:`, error);
    throw error; 
  }
}

function generateOptimizedScript(configs: any[], siteId: string) {
  console.log(`flux-optimizer-script: Generating script for ${configs.length} configurations, site ${siteId}`);
  let script = `// Flux Revenue - Optimization Script v2.1\n`;
  script += `// Site ID: ${siteId}\n`;
  script += `// Generated: ${new Date().toISOString()}\n`;
  script += `// Active optimizations: ${configs.length}\n\n`;
  script += `console.log('[FluxRevenue] Initializing Optimization Script v2.1 for site ${siteId}...');\n`;

  if (configs.length === 0) {
    script += `console.log('[FluxRevenue] No active optimizations found for this site.');\n`;
    return script;
  }

  configs.forEach((config, index) => {
    const configName = config.config_name || `CONFIG_${index + 1}`;
    script += `// --- Optimization: ${configName.toUpperCase()} ---\n`;
    if (config.config && typeof config.config.code === 'string' && config.config.code.trim() !== '') {
      script += `try {\n`;
      script += `  console.log('[FluxRevenue] Applying ${configName}...');\n`;
      script += `  ${config.config.code.trim()}\n`;
      script += `  console.log('[FluxRevenue] ${configName} applied.');\n`;
      script += `} catch(e) { console.error('[FluxRevenue] Error in ${configName}:', e); }\n\n`;
    } else {
      script += `console.log('[FluxRevenue] ${configName} loaded (no executable code provided).');\n\n`;
    }
  });

  script += `console.log('[FluxRevenue] All ${configs.length} optimizations processed for site ${siteId}. Script setup complete.');\n`;
  return script;
}

Deno.serve(async (req) => {
  const corsHeaders = getCorsHeaders(req.headers);

  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders, status: 200 });
  }

  const startTime = Date.now();
  let errorResponseScript = (message: string) => `// Flux Revenue - Error\n// ${message}\nconsole.error('Flux Revenue Error: ${message}');`;

  try {
    console.log('flux-optimizer-script: Request received:', { method: req.method, url: req.url });

    if (req.method !== 'GET') {
      return new Response(errorResponseScript('Method Not Allowed. Use GET.'), {
        status: 405, headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': 'Method Not Allowed' }
      });
    }

    const url = new URL(req.url);
    const siteId = url.searchParams.get('site');
    const token = url.searchParams.get('token');
    const version = url.searchParams.get('v') || 'latest';

    if (!siteId || !token) {
      return new Response(errorResponseScript('Missing required parameters: site ID and token.'), {
        status: 400, headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': 'Site ID and token are required' }
      });
    }
    console.log('flux-optimizer-script: Processing request for site:', siteId);

    const supabaseUrl = Deno.env.get('SUPABASE_URL');
    const supabaseServiceKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY');

    if (!supabaseUrl || !supabaseServiceKey) {
      console.error('flux-optimizer-script: SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY not set.');
      return new Response(errorResponseScript('Server configuration error.'), {
        status: 500, headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': 'Server configuration error' }
      });
    }
    const supabaseAdmin = createClient(supabaseUrl, supabaseServiceKey);

    const { data: siteData, error: siteError } = await supabaseAdmin
      .from('sites')
      .select('id, optimization_token')
      .eq('id', siteId)
      .single();

    if (siteError) {
      console.warn('flux-optimizer-script: Error fetching site data.', { siteId, dbErrorCode: siteError.code, dbErrorMessage: siteError.message });
      const status = siteError.code === 'PGRST116' ? 404 : 500;
      const clientMessage = siteError.code === 'PGRST116' ? 'Site not found.' : 'Error validating site.';
      return new Response(errorResponseScript(clientMessage), {
        status, headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': clientMessage }
      });
    }
    
    if (!siteData) {
        console.warn('flux-optimizer-script: Site not found (no data).', { siteId });
        return new Response(errorResponseScript('Site not found.'), {
            status: 404, headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': 'Site not found' }
        });
    }

    if (siteData.optimization_token !== token) {
      console.warn('flux-optimizer-script: Invalid optimization token.', { siteId });
      return new Response(errorResponseScript('Invalid token.'), {
        status: 403, headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': 'Forbidden - Invalid token' }
      });
    }
    console.log('flux-optimizer-script: Token validated for site:', siteId);

    const configs = await getActiveOptimizations(siteId, supabaseAdmin);
    const optimizedScript = generateOptimizedScript(configs, siteId);
    const processingTime = Date.now() - startTime;

    console.log('flux-optimizer-script: Script generated successfully.', { siteId, configsCount: configs.length, scriptLength: optimizedScript.length, processingTime });
    
    return new Response(optimizedScript, {
      headers: {
        ...corsHeaders,
        'Content-Type': 'application/javascript; charset=utf-8',
        'Cache-Control': 'public, max-age=3600',
        'X-Flux-Version': version,
        'X-Flux-Configs-Applied': configs.length.toString(),
        'X-Flux-Processing-Time-Ms': processingTime.toString()
      },
      status: 200
    });

  } catch (error: any) {
    const processingTime = Date.now() - startTime;
    console.error('flux-optimizer-script: Script generation failed.', { error: error.message, stack: error.stack, processingTime });
    return new Response(errorResponseScript(error.message || 'Internal server error during script generation.'), {
      status: 500, 
      headers: { ...corsHeaders, 'Content-Type': 'application/javascript; charset=utf-8', 'X-Flux-Error': error.message }
    });
  }
});
